# Скопируй этот файл в .env и впиши свои значения.
# .env в .gitignore — секреты в git НЕ попадут.

# Адрес твоего проекта Supabase (уже известен):
SUPABASE_URL=https://oqivrkghvpbybildfjtn.supabase.co

# СЕКРЕТНЫЙ ключ service_role (Supabase → Project Settings → API → service_role).
# Он даёт полный доступ к базе — его держим ТОЛЬКО на сервере/локально, никогда в git и не в браузере.
SUPABASE_SERVICE_KEY=сюда_вставить_ключ

# Имя агента, которым работает этот worker (должно совпадать с записью в таблице agents):
AGENT_NAME=Takopi

# МОЗГ агента — ключ Groq (https://console.groq.com/keys).
# Без него агент работает «без мозга» (заглушка). С ним — реально думает над задачей.
GROQ_API_KEY=сюда_вставить_ключ_groq
# (необязательно) какая модель Groq; по умолчанию llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.3-70b-versatile
# ВЕБ-ПОИСК для Исследователя — ключ Tavily (https://app.tavily.com, бесплатно 1000/мес).
# Без него Исследователь отвечает «из головы» (без свежих данных и ссылок).
# С ним — реально ищет в интернете и даёт сводку со ссылками-источниками.
TAVILY_API_KEY=сюда_вставить_ключ_tavily
